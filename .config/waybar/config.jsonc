// -*- mode: jsonc -*-
{
    "layer": "bottom", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    // "height": 30, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    "spacing": 0, // Gaps between modules (4px)
    "margin-top": 5,
    "margin-left": 5,
    "margin-right":5,
    // Choose the order of the modules

    "modules-left": [
        "custom/launcher",
        "hyprland/window"
        
        // "hyprland/mode",
        // "hyprland/scratchpad",

        
    ],
    "modules-center": [
        "custom/waybar-mpris",
        "hyprland/workspaces",
        "clock"
        



    ],
    "modules-right": [
        
        


        // "pulseaudio",
        // "backlight",
        // "cpu",
        // "memory",
        // "temperature",
        
        // "network",
        
        "tray",
        "custom/seperator2",
        "custom/notification",
        "battery",

    ],
    // Modules configuration
     "hyprland/workspaces": {
         "warp-on-scroll": true,
        "format": "{name}",
        "format-icons": {
              "default": "â€¢"
        },

         "persistent-workspaces": {
            "*": 5
        }
     },

    "network": {
    "interface": "wlan0",
    "format": "",
    "format-wifi": "<span size='16pt'>َ°¤¥</span> ",
    "format-ethernet": "{ipaddr}/{cidr} َ°ٹ—",
    "format-disconnected": "<span size='16pt'>َ°¤­</span>", //An empty format will hide the module.
    "tooltip-format": "{ifname} via {gwaddr} َ°ٹ—",
    "tooltip-format-wifi": "{essid}",
    "tooltip-format-ethernet": "{ifname} ïƒپ",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50
},

    "custom/seperator":{
        "format": "<span size='15pt'> | </span>"
    },

    "custom/seperator2":{
        "format": "<span size='15pt'>  â€¢ </span>"
    },

    "hyprland/window": {
        "max-length": 50
    },

    "hyprland/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "ï‹’"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon} {artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) â¸¨{songPosition}|{queueLength}â¸© {volume}% ï€پ",
        "format-disconnected": "Disconnected ï€پ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon} Stopped ï€پ",
        "unknown-tag": "N/A",
        "interval": 5,
        "consume-icons": {
            "on": "ïƒ„ "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">ïپ´</span> ",
            "on": "ïپ´ "
        },
        "repeat-icons": {
            "on": "ï€‍ "
        },
        "single-icons": {
            "on": "ï€‍1 "
        },
        "state-icons": {
            "paused": "ïپŒ",
            "playing": "ïپ‹"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ïپ®",
            "deactivated": "ïپ°"
        }
    },
    "tray": {
        "icon-size": 21,
        "spacing": 10,
        "tooltip": true,
        "icons": {
           "blueman": "bluetooth",
           "TelegramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png"
         }
    },
"clock": {
        "format": "{:%H:%M  â€¢  %A, %B %d, %Y}",
        "tooltip-format": "{:L%A, %B %d, %Y}"
},
    "cpu": {
        "format": "{usage}% ï‹›",
        "tooltip": false
    },
    "memory": {
        "format": "{}% ïƒ‰"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}آ°C {icon}",
        "format": "{temperatureC}آ°C {icon}",
        "format-icons": ["ï‌«", "ï‹‰", "ï‌©"]
    },

    "battery": {
        "states": {
            "full": 100,
            "normal": 99,
            "warning": 50,
            "critical": 15
        },
        "format": "{capacity}",

        // "format-full": "{capacity}",
        // "format-alt": "{capacity}% {icon}",
        // // "format-good": "", // An empty format will hide the module
        // // "format-full": "",
        // "format-icons": ["ï‰„", "ï‰ƒ", "ï‰‚", "ï‰پ", "ï‰€"]
    },



    "battery#bat2": {
        "bat": "BAT2",
    },
    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "ïƒ§",
        "performance": "ïƒ§",
        "balanced": "ï‰ژ",
        "power-saver": "ïپ¬"
      }
    },

    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "<span size='16pt'>{icon}</span>",
        "format-bluetooth": "{volume}% {icon}ïٹ” {format_source}",
        "format-bluetooth-muted": "ïڑ© {icon}ïٹ” {format_source}",
        "format-muted": "{format_source}",
        "format-source": "{volume}% ï„°",
        "format-source-muted": "َ°–پ",
        "format-icons": {
            "headphone": "ï€¥",
            "hands-free": "ï–گ",
            "headset": "ï–گ",
            "phone": "ï‚•",
            "portable": "ï‚•",
            "car": "ï†¹",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "tooltip": true,
        "tooltip-format": "{volume}%",
        "on-click": "pavucontrol"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "<span size='15pt'>{icon}</span>",
        "format-icons": ["ï”¢"],
        "tooltip-format": "{percent}%"
    },

    "custom/media": {
        "format": "{icon} {text}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "ï†¼",
            "default": "ًںژœ"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null", // Script in resources folder
        "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    },
    "custom/power": {
        "format" : "âڈ» ",
		"tooltip": false,
		"menu": "on-click",
		"menu-file": "$HOME/.config/waybar/power_menu.xml", // Menu file in resources folder
		"menu-actions": {
			"shutdown": "shutdown",
			"reboot": "reboot",
			"suspend": "systemctl suspend",
			"hibernate": "systemctl hibernate"
		}
    },
    "custom/notification": {
    "tooltip": true,
    "format": "<span size='15pt'>َ°‚¯ َ°¤¥ </span>",
    "format-icons": {
      "notification": "َ±…«",
      "none": "َ°‚œ",
      "dnd-notification": "َ°‚ ",
      "dnd-none": "َ°ھ“",
      "inhibited-notification": "َ°‚›",
      "inhibited-none": "َ°ھ‘",
      "dnd-inhibited-notification": "َ°‚›",
      "dnd-inhibited-none": "َ°ھ‘"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "custom/launcher": {
    "format": "<span size='16pt'>{icon}</span> ",
    "format-icons": "َ°£‡",
    "tooltip": false,
    "on-click": "~/.config/rofi/launchers/launcher.sh"
  },
  "gamemode": {
    "format": "{glyph}",
    "format-alt": "{glyph} {count}",
    "glyph": "ï‍³",
    "hide-not-running": true,
    "use-icon": true,
    "icon-name": "input-gaming-symbolic",
    "icon-spacing": 4,
    "icon-size": 20,
    "tooltip": true,
    "tooltip-format": "Games running: {count}"
},

    "custom/waybar-mpris": {
    "return-type": "json",
    "exec": "waybar-mpris --autofocus --play 'ï…„  ' --pause 'ïٹ‹  '",
    "max-length": 30,
    "on-click": "waybar-mpris --send toggle",
    // This option will switch between players on right click.
        "on-click-right": "waybar-mpris --send player-next",
    // The options below will switch the selected player on scroll
        // "on-scroll-up": "waybar-mpris --send player-next",
        // "on-scroll-down": "waybar-mpris --send player-prev",
    // The options below will go to next/previous track on scroll
        // "on-scroll-up": "waybar-mpris --send next",
        // "on-scroll-down": "waybar-mpris --send prev",
    "escape": true
    }
}
